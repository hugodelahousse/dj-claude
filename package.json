{
  "name": "dj-claude",
  "version": "0.1.3",
  "type": "module",
  "description": "Spotify MCP server for music discovery and playback control",
  "license": "MIT",
  "keywords": [
    "spotify",
    "mcp",
    "claude",
    "music",
    "discovery"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "bin": {
    "dj-claude": "./build/index.js"
  },
  "scripts": {
    "build": "bun run tsc && chmod 755 build/index.js",
    "auth": "bun run src/auth/cli.ts",
    "dev": "bun run src/index.ts",
    "dev:install": "bun build --compile src/index.ts --outfile ~/.local/bin/dj-claude",
    "test": "bun test",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@typescript/native-preview": "^7.0.0-dev.20260318.1",
    "typescript": "^5.9.3"
  }
}
